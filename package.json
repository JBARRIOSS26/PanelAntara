{
  "name": "antara-pos-root",
  "version": "1.0.0",
  "description": "Root workspace for ANTARA POS",
  "private": true,
  "scripts": {
    "install:sub": "npm install --prefix backend && npm install --prefix frontend --legacy-peer-deps",
    "postinstall": "npm run install:sub",
    "build": "npm run build --prefix frontend && npm run build --prefix backend",
    "start": "npm run start --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
